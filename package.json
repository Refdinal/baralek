{
  "name": "wedding-invitation-app",
  "version": "1.0.0",
  "description": "Premium Wedding Invitation with Express.js backend and React Vite frontend, ready for Vercel",
  "main": "api/index.js",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "nodemon api/index.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "vite build",
    "start": "node api/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.378.0",
    "pg": "^8.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "vite": "^5.2.0"
  }
}
