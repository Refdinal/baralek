# Port untuk server backend lokal
PORT=3000

# String koneksi Neon PostgreSQL
# Dapatkan di https://neon.tech → Dashboard → Connection Details → Connection String
DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/wedding_db?sslmode=require

# Kredensial Admin Dashboard
ADMIN_USER=admin
ADMIN_PASSWORD=ganti_password_anda_disini

# Secret key untuk JWT token (ganti dengan string acak yang panjang)
JWT_SECRET=ganti-dengan-secret-key-acak-yang-panjang
